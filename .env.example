# MCP4BAS environment template
# Copy to `.env` and adjust for your site/lab.

# ---------------------------------
# Global safety controls
# ---------------------------------
BAS_OPERATION_MODE=read-only
BAS_DRY_RUN=true

# ---------------------------------
# BACnet settings
# ---------------------------------
BACNET_ENABLED=false
BACNET_LOCAL_ADDRESS=host:0
BACNET_TARGET_ADDRESS=
BACNET_NETWORK=0
BACNET_DEVICE_INSTANCE=599001
BACNET_DEVICE_NAME=MCP4BAS
BACNET_VENDOR_IDENTIFIER=999
BACNET_TIMEOUT_SECONDS=3.0
BACNET_RETRIES=1
BACNET_WRITE_ENABLED=false
BACNET_WRITE_PRIORITY_DEFAULT=
# Semicolon-separated list of object_id:property
# Example: analog-value,1:present-value;binary-output,2:present-value
BACNET_WRITE_ALLOWLIST=

# ---------------------------------
# Modbus settings
# ---------------------------------
MODBUS_ENABLED=false
MODBUS_HOST=127.0.0.1
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_TIMEOUT_SECONDS=3.0
MODBUS_RETRIES=1
MODBUS_WRITE_ENABLED=false
# Semicolon-separated list of register:<address> or coil:<address>
# Example: register:10;coil:7
MODBUS_WRITE_ALLOWLIST=

# ---------------------------------
# Niagara / Haystack settings
# ---------------------------------
HAYSTACK_ENABLED=false
# dataset (local file) or api (remote endpoint)
HAYSTACK_MODE=dataset
HAYSTACK_DATASET_PATH=resources/haystack_points.json
HAYSTACK_ENDPOINT=
HAYSTACK_AUTH_TOKEN=
HAYSTACK_TIMEOUT_SECONDS=5.0
# Comma-separated filters (optional)
# Example: HQ-Retrofit,Legacy-Wing
HAYSTACK_PROJECT_FILTERS=
HAYSTACK_SITE_FILTERS=

# ---------------------------------
# MQTT settings
# ---------------------------------
MQTT_ENABLED=false
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_TLS_ENABLED=false
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=mcp4bas
MQTT_TOPIC_PREFIX=
MQTT_SCHEMA_VERSION=v0.1
MQTT_DATASET_PATH=resources/mqtt_messages.json
# simulated (default) or paho
MQTT_RUNTIME=simulated

# MQTT publish safety controls
MQTT_WRITE_ENABLED=false
# Semicolon-separated exact topics allowed for controlled publish
# Example: hq-east/ahu-1/zone-temp;hq-east/ahu-1/supply-fan-cmd
MQTT_PUBLISH_ALLOWLIST=
